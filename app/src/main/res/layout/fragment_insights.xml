<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/header_gradient"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Insights"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Monthly / Weekly Toggle -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#EBEBEB"
                android:padding="4dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/btnMonthly"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monthly"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="#FFFFFF"
                    android:textColor="#1A1A2E"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/btnWeekly"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weekly"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="#EBEBEB"
                    android:textColor="#9E9E9E"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- Stability Summary -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="Stability Summary"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Based on your recent logs and symptom patterns."
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="8dp"
                        android:text="Stability Score"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvStabilityScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="78%"
                        android:textSize="28sp"
                        android:textStyle="bold"/>
                    <com.vishal.cycleapp.custom_views.StabilityChartView
                        android:id="@+id/stabilityChart"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Cycle Trends -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="Cycle Trends"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <com.vishal.cycleapp.custom_views.CycleTrendsView
                    android:id="@+id/cycleTrendsView"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:padding="16dp"/>
            </androidx.cardview.widget.CardView>

            <!-- Body and Metabolic Trends -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="Body and Metabolic Trends"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your weight"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="in kg"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"/>
                    <com.vishal.cycleapp.custom_views.WeightChartView
                        android:id="@+id/weightChart"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Body Signals -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="Body Signals"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Symptom Trends"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingBottom="8dp"
                        android:text="Compared to last cycle"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"/>
                    <com.vishal.cycleapp.custom_views.DonutChartView
                        android:id="@+id/donutChart"
                        android:layout_width="match_parent"
                        android:layout_height="250dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Lifestyle Impact -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="Lifestyle Impact"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="12dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Correlation Strength"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <!-- Clickable "4 months" dropdown -->
                        <LinearLayout
                            android:id="@+id/layoutMonthPicker"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingStart="8dp"
                            android:paddingEnd="4dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <TextView
                                android:id="@+id/tvMonthRange"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4 months"
                                android:textColor="#9E9E9E"
                                android:textSize="12sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" ▾"
                                android:textColor="#9E9E9E"
                                android:textSize="12sp"/>
                        </LinearLayout>

                    </LinearLayout>
                    <com.vishal.cycleapp.custom_views.CorrelationGridView
                        android:id="@+id/correlationGrid"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>